+                    "returning zero-cost fallback answers.",
                     elapsed, max_runtime, remaining,
                 )
 
@@ -548,6 +549,28 @@ def run_pipeline(config: Config) -> tuple[list[TaskResult], list[Task]]:
                 continue
             # If try_solve_math returned None, fall through to local inference
 
