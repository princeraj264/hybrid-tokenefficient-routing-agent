+def _run_local_with_timeout(
+    model: LocalModel,
+    prompt: str,
+    max_tokens: int,
+    timeout: float,
+) -> tuple[str, float, int] | None:
+    """
+    Run local model generation with a hard per-task timeout via a daemon thread.
+
+    The background thread has daemon=True so it NEVER blocks process exit.
+    On timeout the thread is abandoned (still running, killed at exit) and
+    we return None immediately — no .join() is ever called on it.
+
+    Returns (answer, confidence, tokens_used) on success.
+    Returns None if:
+      * The generation exceeded *timeout* seconds (daemon abandoned).
+      * A previous timed-out generation is still in-flight (llama.cpp
+        context is not safe for concurrent calls).
+      * The underlying generate() raised an exception.
+    """
+    global _local_thread, _local_event, _local_result_container
+
+    # If a previous generation is still running in the background, we
+    # cannot safely call into llama.cpp again — escalate to remote
+    # rather than risking concurrent access to the model context.
+    if _local_thread is not None and _local_thread.is_alive():
+        log.warning(
+            "Local model busy — previous call still in-flight, "
+            "skipping local inference",
+        )
+        return None
+
+    # Reset state for the new call
+    _local_result_container = []
+    _local_event.clear()
+
+    def _worker(
+        m: LocalModel, p: str, mt: int,
+    ) -> None:
+        try:
+            result = m.generate(p, mt)
+            _local_result_container.append(result)
+        except Exception as exc:
+            _local_result_container.append(exc)
+        finally:
+            _local_event.set()
+
+    _local_thread = threading.Thread(
+        target=_worker,
+        args=(model, prompt, max_tokens),
+        daemon=True,
+    )
+    _local_thread.start()
+
+    # Wait for the worker with the per-task timeout
+    if _local_event.wait(timeout=timeout):
+        # Worker completed within budget
+        val = _local_result_container[0]
+        if isinstance(val, Exception):
+            log.warning(
+                "Local generation raised an exception: %s \u2014 "
+                "escalating to remote",
+                val,
+            )
+            return None
+        return val  # (answer, confidence, tokens_used)
+
+    # Timeout: the daemon thread is still running but will be killed
+    # at process exit — we return None immediately (never .join())
+    log.warning(
+        "Local generation timed out after %.0fs — abandoning "
+        "daemon thread (killed at process exit)",
+        timeout,
+    )
+    return None
+
