+def _run_local_with_timeout(
+    model: LocalModel,
+    prompt: str,
+    max_tokens: int,
+    timeout: float,
+) -> tuple[str, float, int] | None:
+    """
+    Run local model generation with a hard per-task timeout.
+
+    Uses a module-level persistent ThreadPoolExecutor so the pool is
+    *never shut down*.  On timeout the background thread is abandoned
+    (it completes silently with results discarded) rather than blocking
+    the caller.
+
+    Returns (answer, confidence, tokens_used) on success.
+    Returns None if:
+      * The generation exceeded *timeout* seconds (thread abandoned).
+      * A previous timed-out generation is still in-flight (llama.cpp
+        context is not safe for concurrent calls).
+      * The underlying generate() raised an exception.
+    """
+    global _local_future
+
+    # If a previous generation is still running in the background, we
+    # cannot safely call into llama.cpp again — escalate to remote
+    # rather than risking concurrent access to the model context.
+    if _local_future is not None and not _local_future.done():
+        log.warning(
+            "Local model busy — previous call still in-flight, "
+            "skipping local inference",
+        )
+        return None
+
+    _local_future = _LOCAL_POOL.submit(model.generate, prompt, max_tokens)
+
+    try:
+        return _local_future.result(timeout=timeout)
+    except concurrent.futures.TimeoutError:
+        log.warning(
+            "Local generation timed out after %.0fs — abandoning "
+            "background thread (results discarded)",
+            timeout,
+        )
+        return None
+    except Exception as exc:
+        log.warning("Local generation failed: %s", exc)
+        _local_future = None
+        return None
+
+
